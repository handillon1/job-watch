# Copy this file to .env and fill in the values below.
# These should match the secrets you set on Mekski/job-watch in GitHub Settings → Actions.

# Telegram bot (required)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Sheets (required)
# Paste either the full JSON content as one line, OR set this to a path to a JSON file on disk.
GOOGLE_SERVICE_ACCOUNT_JSON=
APPLICATIONS_SHEET_ID=

# Bot's own GitHub repo (required) — used to query GH Actions API for run history.
# This is the repo hosting the bot itself, NOT the upstream job repos being watched.
BOT_REPO=Mekski/job-watch

# Optional: a GitHub PAT (any scopes work; only used for higher API rate limits).
# Without this, GH API calls are unauthenticated (60 req/hr instead of 5000).
# GITHUB_TOKEN=
